{
  "name": "agents-remote",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "web",
    "api",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run dev:api & bun run dev:web",
    "dev:api": "bun run --filter @agents-remote/api dev",
    "dev:web": "scripts/ar-dev-web.sh",
    "dev:web:hmr": "bun run --filter @agents-remote/web dev",
    "e2e": "bun run scripts/run-e2e.ts",
    "build": "bun run --sequential --workspaces build",
    "typecheck": "bun run --sequential --workspaces typecheck && tsc -p tsconfig.e2e.json",
    "lint": "oxlint package.json tsconfig.json tsconfig.base.json tsconfig.e2e.json playwright.config.ts scripts e2e api packages web --deny-warnings",
    "format": "oxfmt package.json tsconfig.json tsconfig.base.json tsconfig.e2e.json playwright.config.ts scripts e2e api packages web",
    "format:check": "oxfmt --check package.json tsconfig.json tsconfig.base.json tsconfig.e2e.json playwright.config.ts scripts e2e api packages web",
    "prepare": "git config core.hooksPath scripts/githooks",
    "test": "bun run --sequential --workspaces test"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.160",
    "@assistant-ui/react-markdown": "^0.14.1",
    "@assistant-ui/react-syntax-highlighter": "^0.14.2",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "refractor": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/bun": "^1.3.4",
    "@types/react-syntax-highlighter": "^15.5.13",
    "oxfmt": "0.50.0",
    "oxlint": "1.65.0",
    "typescript": "^5.9.3",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-window": "^7.4.1"
  }
}
